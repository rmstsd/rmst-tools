{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "files": ["src/preload/index.d.ts"],
  "include": ["src/renderer/src/env.d.ts", "src/renderer/src/**/*", "src/renderer/src/**/*.tsx"],
  "compilerOptions": {
    "composite": true,
    "strict": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"]
    }
  }
}
