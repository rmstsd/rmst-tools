{
  "name": "rmst-tools",
  "version": "2.0.6",
  "description": "RMST tools rebuilt with Electron, React and Semi Design",
  "main": "./out/main/index.js",
  "author": "rmstsd",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "dev": "chcp 65001 > nul && electron-vite dev --watch",
    "start": "chcp 65001 > nul && electron-vite preview",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "release-it": "release-it patch --ci"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "^2.99.2",
    "@douyinfe/semi-ui": "^2.99.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "koffi": "^3.0.1",
    "qrcode.react": "^4.2.0",
    "selection-hook": "^2.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "less": "^4.6.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "release-it": "^17.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
